{
  "name": "mcmc-visualizer",
  "version": "0.1.0",
  "description": "Parse, analyze, plot, and export MCMC sampling data. Supports ArviZ JSON, Turing CSV, Stan CSV, and MCMCChains formats with production-grade diagnostics (ESS bulk/tail, rank R-hat, MCSE, HDI) and interactive Plotly.js visualizations.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcmc": "./dist/cli/index.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plots": {
      "types": "./dist/plots/index.d.ts",
      "import": "./dist/plots/index.js",
      "require": "./dist/plots/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write src tests",
    "lint": "tsc --noEmit && biome lint src",
    "check": "biome check --write src",
    "prepublishOnly": "npm run build && npm run lint",
    "docs:dev": "vitepress dev website",
    "docs:build": "vitepress build website",
    "docs:preview": "vitepress preview website"
  },
  "keywords": [
    "mcmc",
    "bayesian",
    "statistics",
    "turing",
    "stan",
    "arviz",
    "ess",
    "rhat",
    "diagnostics",
    "sampling",
    "plotly",
    "visualization",
    "inference-data",
    "pymc",
    "numpyro",
    "posterior"
  ],
  "license": "MIT",
  "peerDependencies": {
    "plotly.js-dist-min": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "plotly.js-dist-min": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.0.0"
  }
}
